{
  "name": "@detecte/cli",
  "version": "0.1.0",
  "description": "Command-line interface for Detecte — runtime security for AI agents.",
  "license": "MIT",
  "homepage": "https://detecte.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/DoctorMathx/detecte-cli.git"
  },
  "bin": {
    "detecte": "./dist/index.js"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node18 --clean --shims",
    "dev": "tsup src/index.ts --format esm --target node18 --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "kleur": "^4.1.5",
    "open": "^10.1.0",
    "ora": "^8.0.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.1.0",
    "typescript": "^5.5.3"
  }
}
